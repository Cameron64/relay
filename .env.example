# --- Server ---
PORT=3000
# 'production' makes the unlock cookie Secure-only. Leave unset/development for localhost.
NODE_ENV=development

# --- Web Push (VAPID) ---
# Generate once:  bunx web-push generate-vapid-keys   (or npx)
# The public key is also served to clients via GET /api/push/public-key.
# The PRIVATE key is a secret — set it on Railway only, never ship it to the browser.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Auth tokens (timing-safe compared via auth.tokensMatch) ---
# WRITE_TOKEN: machine side (relay CLI + Claude Code hooks). Sent as the x-write-token
#   header to create cards / broadcast push / read verdicts. NEVER ships to the browser.
# UI_TOKEN: browser side. Pasted once into the PWA unlock screen, exchanged at
#   POST /api/unlock for an httpOnly cookie. Lower-privilege (read feed + respond only).
# Both: openssl rand -hex 32   (or `bun -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
WRITE_TOKEN=
UI_TOKEN=

# --- Cards storage tuning ---
CARD_RETENTION_DAYS=30        # prune cards older than this on boot + after create
CARD_MAX=500                  # hard cap on retained cards (oldest pruned beyond this)
ASSET_MAX_BYTES=3145728       # 3 MB per-image cap; larger uploads rejected with 413

# --- SQLite location (default storage) ---
# On Railway, attach a volume; Railway sets RAILWAY_VOLUME_MOUNT_PATH and the app writes
# <mount>/app.db automatically. Locally it falls back to ./.data/app.db.
# DB_PATH=/data/app.db
